rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'ikcdeveloper@gmail.com';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /apps/{appId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();

      match /downloaders/{uid} {
        allow read: if isAdmin();
        allow create: if isAuthenticated() && request.auth.uid == uid;
      }

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/apps/$(appId)).data.status == 'published' || isAdmin();
        allow create: if isAuthenticated()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      match /favorites/{appId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /versions/{appId}/history/{versionId} {
      allow read: if isAdmin() || get(/databases/$(database)/documents/apps/$(appId)).data.status == 'published';
      allow write: if isAdmin();
    }
  }
}
