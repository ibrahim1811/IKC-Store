rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'ikcdeveloper@gmail.com';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /apps/{appId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    match /versions/{appId}/history/{versionId} {
      allow read: if isAdmin() || get(/databases/$(database)/documents/apps/$(appId)).data.status == 'published';
      allow write: if isAdmin();
    }
  }
}
